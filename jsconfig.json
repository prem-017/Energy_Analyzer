{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "checkJs": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "lib": ["es2020", "dom"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "dist/*",
    "dist/**/*",
    "public/dist",
    "public/dist/*",
    "public/dist/**/*"
  ]
}
